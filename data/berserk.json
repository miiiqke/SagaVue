  "watchGuide": [
    {
      "step": 1,
      "type": "choice",
      "label": "Golden Age — Pick ONE",
      "note": "Both options cover the same manga chapters (Ch 9–94). Watch one or the other, not both.",
      "options": [
        {
          "type": "anime",
          "title": "Berserk (1997)",
          "subtitle": "25 episodes",
          "covers": "Ch 1–2, 9–94",
          "malId": 33,
          "note": "Partially covers Black Swordsman arc (ch 1–2), then tells the full Golden Age. Ends on a cliffhanger — no post-Eclipse resolution."
        },
        {
          "type": "movie-set",
          "title": "Golden Age Arc Film Trilogy",
          "subtitle": "3 films",
          "covers": "Ch 9–94",
          "malIds": [
            10218,
            12113,
            12115
          ],
          "note": "Retelling with updated animation. Skips the Black Swordsman opening. Film III has an extended Eclipse sequence."
        }
      ]
    },
    {
      "step": 2,
      "type": "manga-required",
      "title": "Read Manga — Lost Children Chapter",
      "covers": "Ch 95–116",
      "note": "This entire sub-arc was NEVER animated — skipped by the 2016 anime with no explanation. You must read it in the manga or you will be confused by what follows."
    },
    {
      "step": 3,
      "type": "anime",
      "title": "Berserk (2016)",
      "subtitle": "12 episodes",
      "covers": "Ch 117–176",
      "malId": 32379,
      "note": "Picks up after the Eclipse. Covers the Binding Chain and Birth Ceremony chapters of the Conviction Arc."
    },
    {
      "step": 4,
      "type": "anime",
      "title": "Berserk (2017)",
      "subtitle": "12 episodes",
      "covers": "Ch 177–237",
      "malId": 34055,
      "note": "Continues directly from 2016. Covers the Holy Evil War chapter of the Millennium Empire Arc — but ends abruptly and leaves large sections unadapted."
    },
    {
      "step": 5,
      "type": "manga-required",
      "title": "Continue Manga — From Chapter 238",
      "covers": "Ch 238–ongoing",
      "startChapter": 238,
      "note": "The anime ends here. The rest of the Millennium Empire Arc (Falconia chapter) and the entire Fantasia Arc have never been animated. The manga is ongoing."
    }
  ],
