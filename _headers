# Cloudflare Pages — HTTP headers
# Applied to every response.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# Long cache for versioned assets (favicons, logo — rarely change)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# No cache for HTML — always fetch fresh so new series data is picked up
/*.html
  Cache-Control: no-cache

# Short cache for JSON data files — fresh within 5 minutes
/data/*.json
  Cache-Control: public, max-age=300, stale-while-revalidate=60
